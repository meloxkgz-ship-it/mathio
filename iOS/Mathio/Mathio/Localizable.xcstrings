      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Integration ist die Umkehrung der Ableitung."
          }
        }
      }
    },
    "In a right triangle, the squared hypotenuse equals the sum of the squared legs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im rechtwinkligen Dreieck gilt: Quadrat der Hypotenuse gleich Summe der Kathetenquadrate."
          }
        }
      }
    },
