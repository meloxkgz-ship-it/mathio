          }
        }
      }
    },
    "A function takes an input and returns exactly one output. f(x) is read 'f of x'.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Funktion nimmt eine Eingabe und gibt genau eine Ausgabe zurück. f(x) liest man „f von x“."
